<?php

/**
 * @file
 * Contém os hooks principais do módulo MikeDelta Termos.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implementa hook_help().
 */
function mikedelta_termos_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.mikedelta_termos':
      $output = '';

      $output .= '<h3>' . t('Sobre o Módulo MikeDelta Termos') . '</h3>';
      $output .= '<p>' . t('O <strong>MikeDelta Termos</strong> é uma ferramenta desenvolvida para a geração automatizada, padronizada e simplificada de Termos para equipes de TI em formato PDF (TRE, TRI ou TRPVM). O processamento ocorre 100% no navegador do usuário (client-side via JavaScript), o que garante alta velocidade e atende aos rigorosos requisitos de segurança em redes isoladas (intranet), pois nenhum dado sensível é enviado para processamento em servidores externos ou do próprio servidor web.') . '</p>';
      
      $output .= '<h4>' . t('Principais Funcionalidades:') . '</h4>';
      $output .= '<ul>';
      $output .= '<li>' . t('Gera PDFs formatados nas normas oficiais com um único clique.') . '</li>';
      $output .= '<li>' . t('Aplica máscaras automáticas em tempo real (ex: NIP e MAC Address) para evitar erros de digitação.') . '</li>';
      $output .= '<li>' . t('Constrói tabelas dinâmicas de softwares instalados (exclusivo para o TRE).') . '</li>';
      $output .= '<li>' . t('Permite edição completa dos textos e programas via painel administrativo, sem a necessidade de alterar o código-fonte.') . '</li>';
      $output .= '<li>' . t('Permite a visualização dos termos antes de serem gerados.') . '</li>';
      $output .= '<li>' . t('Ajusta as opções de Posto/Graduação e Quadro/Especialidade automaticamente com base na escolha de hierarquia - Oficial ou Praça.') . '</li>';
      $output .= '</ul>';

      $output .= '<h3>' . t('Acesso e Configuração da OM Padrão') . '</h3>';
      $output .= '<p>' . t('A interface de preenchimento do gerador não é adicionada aos menus automaticamente. Ela deve ser acessada pelos usuários na URL: <strong>/gerador-termos</strong>. Esse endereço pode ser adicionado a qualquer menu criado no site.') . '</p>';
      $output .= '<p>' . t('Na aba <strong>Global</strong> das configurações do módulo, você define a "Organização Militar (OM) Padrão". A dinâmica desse campo no formulário funciona da seguinte maneira:') . '</p>';
      $output .= '<ul>';
      $output .= '<li>' . t('Se o usuário <strong>deixar o campo OM em branco</strong>, o PDF será gerado utilizando a sigla cadastrada nas configurações Globais (Vazio).') . '</li>';
      $output .= '<li>' . t('Se o usuário <strong>digitar qualquer valor</strong> no campo, o sistema dará total prioridade ao que foi digitado, ignorando a configuração padrão para aquele PDF específico. Na geração do termo, existe este mesmo campo e ao ser preenchido a prioridade será deste campo.') . '</li>';
      $output .= '</ul>';

      $output .= '<h3>' . t('Como editar os textos e a particularidade do TRE') . '</h3>';
      $output .= '<p>' . t('Os textos dos termos podem ser editadas acessando as respectivas abas nas configurações. Para o TRI e o TRPVM, a geração do texto é linear (corrida). No entanto, o <strong>TRE (Termo de Responsabilidade de Estação de Trabalho)</strong> exige uma formatação especial devido à lista de softwares.') . '</p>';
      $output .= '<p>' . t('<strong>Atenção à regra do TRE:</strong> O algoritmo busca exatamente a frase <code>II – de instalação de programas:</code> no seu texto. Ele "corta" o documento nessa exata linha, injeta a <strong>Tabela de Programas</strong> logo abaixo dela, e depois continua a imprimir o restante do texto (Item III, IV, etc.). Se você apagar, alterar a pontuação ou a grafia dessa frase no painel, o sistema não saberá onde dividir o texto e a tabela de programas será jogada para o final do documento. Uma melhoria nesta seção será desenvolvida conforme atualização 100% da redação de qualquer um dos Termos deste módulo.') . '</p>';

      $output .= '<h3>' . t('O uso das Variáveis (Tags Curingas)') . '</h3>';
      $output .= '<p>' . t('Os textos utilizam "variáveis" (palavras protegidas por colchetes) que funcionam como marcações espaciais. No momento do clique em "Gerar PDF", o script localiza essas marcações e as substitui instantaneamente pelos dados reais preenchidos pelo usuário.') . '</p>';
      $output .= '<ul>';
      $output .= '<li><strong>Exemplo prático:</strong> A marcação <code>[NOME_COMPLETO]</code> será apagada e trocada por "FULANO DA SILVA".</li>';
      $output .= '<li><strong>Regra de Ouro:</strong> Nunca altere o padrão visual das variáveis. Não remova os colchetes, não mude para letras minúsculas e não adicione espaços dentro delas (ex: usar <code>[ NIP ]</code> em vez de <code>[NIP]</code>). O módulo foi programado para localizar a string exata. Se a grafia for alterada, a substituição falhará e a tag literal aparecerá impressa no PDF final, causando inconsistência no arquivo gerado.</li>';
      $output .= '</ul>';

      $output .= '<h3>' . t('Feedback e Evolução') . '</h3>';
      $output .= '<p>' . t('Este módulo foi desenvolvido com foco total na otimização do fluxo de trabalho administrativo, na usabilidade e na conformidade com as normas em vigor. O uso em ambiente de produção é o melhor termômetro para a qualidade de um software.') . '</p>';
      $output .= '<p>' . t('Caso encontre comportamentos inesperados (bugs), tenha sugestões de novas funcionalidades ou precise relatar melhorias de código, por favor, envie um feedback diretamente ao criador do módulo através do e-mail corporativo:') . '</p>';
      $output .= '<blockquote><strong>dias.marcelo@marinha.mil.br</strong></blockquote>';
      $output .= '<p>' . t('Seus relatos são extremamente importantes e servem como combustível para as melhorias e futuras atualizações desta solução.') . '</p>';
      $output .= '<p>' . t('Este módulo foi desenvolvido por Marcelo Dias da Silva.') . '</p>';

      return $output;
  }
}

/**
 * Implementa hook_theme().
 */
function mikedelta_termos_theme($existing, $type, $theme, $path) {
  return [
    'mikedelta_termos_admin_block' => [
      'variables' => [
        'dados_termos' => NULL,
      ],
    ],
  ];
}